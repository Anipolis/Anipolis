{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"files": {
		"ignoreUnknown": false,
		"includes": [ "**", "!**/package.json" ]
	},
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"formatter": {
		"indentWidth": 4,
		"lineWidth": 120
	},
	"linter": {
		"rules": {
			"recommended": true
		}
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"html": {
		"experimentalFullSupportEnabled": true,
		"formatter": {
			"enabled": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	}
}
